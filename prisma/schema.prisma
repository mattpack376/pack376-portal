generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DEN
  ATTENDANCE_ADMIN
  JUNIOR_ADMIN
  PHOTOGRAPHER
  PARENT
}

enum DeadlineCategory {
  CAMPING
  DAY_TRIP
  SPECIAL_EVENT
  GENERAL
}

enum Rank {
  LION
  TIGER
  WOLF
  BEAR
  WEBELOS
  AOL
}

enum AdventureType {
  REQUIRED
  ELECTIVE
}

enum MeetingStatus {
  SCHEDULED
  NO_MEETING
}

enum ConsentStatus {
  PENDING
  CONSENT
  DECLINE
}

enum SignerRelationship {
  PARENT
  GUARDIAN
  GRANDPARENT
  AUNT_UNCLE
  ADULT_SIBLING
}

model User {
  id                  String               @id @default(cuid())
  username            String               @unique
  passwordHash        String
  role                Role
  email               String?
  displayName         String
  failedLoginCount    Int                  @default(0)
  lockedUntil         DateTime?
  // Bumped whenever the account's password, role, or den assignments change.
  // The value is embedded in the session JWT; a mismatch on any protected
  // request invalidates already-issued tokens (see src/lib/auth.ts).
  sessionVersion      Int                  @default(0)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  advancementUpdates  AdvancementRecord[]
  attendanceUpdates   Attendance[]
  duesPaymentsLogged  DuesPayment[]
  denAssignments      DenAssignment[]
  resetTokens         PasswordResetToken[]
  // A PARENT-role account may link to more than one Parent contact row (one
  // per scout) when siblings share the same parent/guardian.
  parentContacts      Parent[]
  announcements       Announcement[]
  eventPaymentsLogged EventPayment[]
}

/**
 * One-time, expiring tokens used both for new-account invites and password
 * resets, so a real password is never generated server-side, emailed, or
 * shown on screen — the account holder always sets it themselves via the
 * link. Only tokenHash is stored; the plaintext token lives in the emailed
 * or displayed URL and is never persisted (see src/lib/resetTokens.ts).
 */
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Den {
  id             String          @id @default(cuid())
  rank           Rank
  scoutingYear   String
  label          String          @default("")
  scouts         Scout[]
  denAssignments DenAssignment[]
  createdAt      DateTime        @default(now())

  @@unique([rank, scoutingYear, label])
}

model DenAssignment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  denId  String
  den    Den    @relation(fields: [denId], references: [id], onDelete: Cascade)

  @@unique([userId, denId])
}

model Scout {
  id                 String              @id @default(cuid())
  denId              String
  den                Den                 @relation(fields: [denId], references: [id], onDelete: Cascade)
  firstName          String
  lastName           String
  notes              String?
  createdAt          DateTime            @default(now())
  records            AdvancementRecord[]
  attendances        Attendance[]
  duesPayments       DuesPayment[]
  parents            Parent[]
  photoConsent       PhotoConsent?
  eventRegistrations EventRegistration[]
}

model Parent {
  id        String   @id @default(cuid())
  scoutId   String
  scout     Scout    @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  // Set once an admin invites this contact to the Parent Portal. Nulled out
  // (not cascaded) if that login is ever deleted, so the contact info on file
  // survives losing portal access.
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Adventure {
  id        String              @id @default(cuid())
  rank      Rank
  name      String
  type      AdventureType
  sortOrder Int
  note      String?
  records   AdvancementRecord[]

  @@unique([rank, name])
}

model AdvancementRecord {
  id              String    @id @default(cuid())
  scoutId         String
  scout           Scout     @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  adventureId     String
  adventure       Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  completed       Boolean   @default(false)
  completedDate   DateTime?
  updatedAt       DateTime  @updatedAt
  updatedByUserId String?
  updatedByUser   User?     @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([scoutId, adventureId])
}

model MeetingDate {
  id          String        @id @default(cuid())
  date        DateTime      @unique @db.Date
  status      MeetingStatus @default(SCHEDULED)
  attendances Attendance[]
}

model Attendance {
  id              String      @id @default(cuid())
  scoutId         String
  scout           Scout       @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  meetingDateId   String
  meetingDate     MeetingDate @relation(fields: [meetingDateId], references: [id], onDelete: Cascade)
  present         Boolean
  updatedAt       DateTime    @updatedAt
  updatedByUserId String?
  updatedByUser   User?       @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([scoutId, meetingDateId])
}

model DuesSettings {
  id           String   @id @default(cuid())
  scoutingYear String   @unique
  amountCents  Int
  updatedAt    DateTime @updatedAt
}

model DuesPayment {
  id               String   @id @default(cuid())
  scoutId          String
  scout            Scout    @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  amountCents      Int
  paidOn           DateTime @db.Date
  note             String?
  createdAt        DateTime @default(now())
  recordedByUserId String?
  recordedByUser   User?    @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)
}

/**
 * Per-scout photo release, reachable only via the plaintext `token` embedded
 * in a link (no family portal accounts). Unlike PasswordResetToken this
 * token never expires or gets marked used — a leader needs to reopen the
 * same link weeks later to check status or resend it, and a parent needs to
 * be able to revisit it and change their answer. It's an unguessable capability
 * URL (crypto-random, same trust level as PhotoAlbum.photoAlbumUrl below),
 * not a login credential, so storing it in plaintext is an acceptable
 * trade-off in exchange for re-viewability. If a link is ever suspected
 * leaked, an admin/den leader can rotate it (see regeneratePhotoConsentTokenAction).
 */
model PhotoConsent {
  id                 String              @id @default(cuid())
  scoutId            String              @unique
  scout              Scout               @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  token              String              @unique
  facebook           ConsentStatus       @default(PENDING)
  website            ConsentStatus       @default(PENDING)
  fliers             ConsentStatus       @default(PENDING)
  signedByName       String?
  signedRelationship SignerRelationship?
  signedDate         DateTime?           @db.Date
  signedAt           DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model PhotoAlbum {
  id            String   @id @default(cuid())
  title         String
  eventDate     DateTime @db.Date
  description   String?
  coverImageUrl String?
  photoAlbumUrl String
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/**
 * Pack-wide notice shown to every family on the Parent Dashboard.
 */
model Announcement {
  id              String   @id @default(cuid())
  title           String
  body            String
  pinned          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdByUserId String?
  createdByUser   User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
}

/**
 * A due date surfaced on the Parent Dashboard — camping/day-trip/event RSVPs, forms, etc.
 */
model Deadline {
  id          String           @id @default(cuid())
  title       String
  category    DeadlineCategory @default(GENERAL)
  dueDate     DateTime         @db.Date
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

/**
 * An open pack-wide volunteer ask shown on the Parent Dashboard.
 */
model VolunteerNeed {
  id          String   @id @default(cuid())
  title       String
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/**
 * A paid pack event (campout, day trip, special event) that scouts sign up for.
 */
model Event {
  id            String              @id @default(cuid())
  title         String
  category      DeadlineCategory    @default(GENERAL)
  eventDate     DateTime            @db.Date
  description   String?
  // Default per-scout cost applied when registering a scout — null means the
  // fee is decided per registration (e.g. varies by family or trip length).
  feeCents      Int?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  registrations EventRegistration[]
}

/**
 * A scout signed up for an Event, with the amount they owe for it.
 */
model EventRegistration {
  id              String         @id @default(cuid())
  eventId         String
  event           Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  scoutId         String
  scout           Scout          @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  amountOwedCents Int
  createdAt       DateTime       @default(now())
  payments        EventPayment[]

  @@unique([eventId, scoutId])
}

model EventPayment {
  id                  String            @id @default(cuid())
  eventRegistrationId String
  eventRegistration   EventRegistration @relation(fields: [eventRegistrationId], references: [id], onDelete: Cascade)
  amountCents         Int
  paidOn              DateTime          @db.Date
  note                String?
  createdAt           DateTime          @default(now())
  recordedByUserId    String?
  recordedByUser      User?             @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)
}
