generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DEN
  ATTENDANCE_ADMIN
  JUNIOR_ADMIN
  PHOTOGRAPHER
}

enum Rank {
  LION
  TIGER
  WOLF
  BEAR
  WEBELOS
  AOL
}

enum AdventureType {
  REQUIRED
  ELECTIVE
}

enum MeetingStatus {
  SCHEDULED
  NO_MEETING
}

model User {
  id                 String              @id @default(cuid())
  username           String              @unique
  passwordHash       String
  role               Role
  email              String?
  displayName        String
  failedLoginCount   Int                 @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  advancementUpdates AdvancementRecord[]
  attendanceUpdates  Attendance[]
  duesPaymentsLogged DuesPayment[]
  denAssignments     DenAssignment[]
}

model Den {
  id             String          @id @default(cuid())
  rank           Rank
  scoutingYear   String
  label          String          @default("")
  scouts         Scout[]
  denAssignments DenAssignment[]
  createdAt      DateTime        @default(now())

  @@unique([rank, scoutingYear, label])
}

model DenAssignment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  denId  String
  den    Den    @relation(fields: [denId], references: [id], onDelete: Cascade)

  @@unique([userId, denId])
}

model Scout {
  id           String              @id @default(cuid())
  denId        String
  den          Den                 @relation(fields: [denId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  notes        String?
  createdAt    DateTime            @default(now())
  records      AdvancementRecord[]
  attendances  Attendance[]
  duesPayments DuesPayment[]
}

model Adventure {
  id        String              @id @default(cuid())
  rank      Rank
  name      String
  type      AdventureType
  sortOrder Int
  note      String?
  records   AdvancementRecord[]

  @@unique([rank, name])
}

model AdvancementRecord {
  id              String    @id @default(cuid())
  scoutId         String
  scout           Scout     @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  adventureId     String
  adventure       Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  completed       Boolean   @default(false)
  completedDate   DateTime?
  updatedAt       DateTime  @updatedAt
  updatedByUserId String?
  updatedByUser   User?     @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([scoutId, adventureId])
}

model MeetingDate {
  id          String        @id @default(cuid())
  date        DateTime      @unique @db.Date
  status      MeetingStatus @default(SCHEDULED)
  attendances Attendance[]
}

model Attendance {
  id              String      @id @default(cuid())
  scoutId         String
  scout           Scout       @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  meetingDateId   String
  meetingDate     MeetingDate @relation(fields: [meetingDateId], references: [id], onDelete: Cascade)
  present         Boolean
  updatedAt       DateTime    @updatedAt
  updatedByUserId String?
  updatedByUser   User?       @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([scoutId, meetingDateId])
}

model DuesSettings {
  id           String   @id @default(cuid())
  scoutingYear String   @unique
  amountCents  Int
  updatedAt    DateTime @updatedAt
}

model DuesPayment {
  id               String   @id @default(cuid())
  scoutId          String
  scout            Scout    @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  amountCents      Int
  paidOn           DateTime @db.Date
  note             String?
  createdAt        DateTime @default(now())
  recordedByUserId String?
  recordedByUser   User?    @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)
}

model PhotoAlbum {
  id            String   @id @default(cuid())
  title         String
  eventDate     DateTime @db.Date
  description   String?
  coverImageUrl String?
  photoAlbumUrl String
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
