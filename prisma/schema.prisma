generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  DEN
  ATTENDANCE_ADMIN
  JUNIOR_ADMIN
  PHOTOGRAPHER
}

enum Rank {
  LION
  TIGER
  WOLF
  BEAR
  WEBELOS
  AOL
}

enum AdventureType {
  REQUIRED
  ELECTIVE
}

enum MeetingStatus {
  SCHEDULED
  NO_MEETING
}

enum ConsentStatus {
  PENDING
  CONSENT
  DECLINE
}

model User {
  id                 String              @id @default(cuid())
  username           String              @unique
  passwordHash       String
  role               Role
  email              String?
  displayName        String
  failedLoginCount   Int                 @default(0)
  lockedUntil        DateTime?
  // Bumped whenever the account's password, role, or den assignments change.
  // The value is embedded in the session JWT; a mismatch on any protected
  // request invalidates already-issued tokens (see src/lib/auth.ts).
  sessionVersion     Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  advancementUpdates AdvancementRecord[]
  attendanceUpdates  Attendance[]
  duesPaymentsLogged DuesPayment[]
  denAssignments     DenAssignment[]
  resetTokens        PasswordResetToken[]
}

/**
 * One-time, expiring tokens used both for new-account invites and password
 * resets, so a real password is never generated server-side, emailed, or
 * shown on screen — the account holder always sets it themselves via the
 * link. Only tokenHash is stored; the plaintext token lives in the emailed
 * or displayed URL and is never persisted (see src/lib/resetTokens.ts).
 */
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Den {
  id             String          @id @default(cuid())
  rank           Rank
  scoutingYear   String
  label          String          @default("")
  scouts         Scout[]
  denAssignments DenAssignment[]
  createdAt      DateTime        @default(now())

  @@unique([rank, scoutingYear, label])
}

model DenAssignment {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  denId  String
  den    Den    @relation(fields: [denId], references: [id], onDelete: Cascade)

  @@unique([userId, denId])
}

model Scout {
  id           String              @id @default(cuid())
  denId        String
  den          Den                 @relation(fields: [denId], references: [id], onDelete: Cascade)
  firstName    String
  lastName     String
  notes        String?
  createdAt    DateTime            @default(now())
  records      AdvancementRecord[]
  attendances  Attendance[]
  duesPayments DuesPayment[]
  parents      Parent[]
  photoConsent PhotoConsent?
}

model Parent {
  id        String   @id @default(cuid())
  scoutId   String
  scout     Scout    @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  phone     String?
  createdAt DateTime @default(now())
}

model Adventure {
  id        String              @id @default(cuid())
  rank      Rank
  name      String
  type      AdventureType
  sortOrder Int
  note      String?
  records   AdvancementRecord[]

  @@unique([rank, name])
}

model AdvancementRecord {
  id              String    @id @default(cuid())
  scoutId         String
  scout           Scout     @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  adventureId     String
  adventure       Adventure @relation(fields: [adventureId], references: [id], onDelete: Cascade)
  completed       Boolean   @default(false)
  completedDate   DateTime?
  updatedAt       DateTime  @updatedAt
  updatedByUserId String?
  updatedByUser   User?     @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([scoutId, adventureId])
}

model MeetingDate {
  id          String        @id @default(cuid())
  date        DateTime      @unique @db.Date
  status      MeetingStatus @default(SCHEDULED)
  attendances Attendance[]
}

model Attendance {
  id              String      @id @default(cuid())
  scoutId         String
  scout           Scout       @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  meetingDateId   String
  meetingDate     MeetingDate @relation(fields: [meetingDateId], references: [id], onDelete: Cascade)
  present         Boolean
  updatedAt       DateTime    @updatedAt
  updatedByUserId String?
  updatedByUser   User?       @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([scoutId, meetingDateId])
}

model DuesSettings {
  id           String   @id @default(cuid())
  scoutingYear String   @unique
  amountCents  Int
  updatedAt    DateTime @updatedAt
}

model DuesPayment {
  id               String   @id @default(cuid())
  scoutId          String
  scout            Scout    @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  amountCents      Int
  paidOn           DateTime @db.Date
  note             String?
  createdAt        DateTime @default(now())
  recordedByUserId String?
  recordedByUser   User?    @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)
}

/**
 * Per-scout photo release, reachable only via the plaintext `token` embedded
 * in a link (no family portal accounts). Unlike PasswordResetToken this
 * token never expires or gets marked used — a leader needs to reopen the
 * same link weeks later to check status or resend it, and a parent needs to
 * be able to revisit it and change their answer. It's an unguessable capability
 * URL (crypto-random, same trust level as PhotoAlbum.photoAlbumUrl below),
 * not a login credential, so storing it in plaintext is an acceptable
 * trade-off in exchange for re-viewability. If a link is ever suspected
 * leaked, an admin/den leader can rotate it (see regeneratePhotoConsentTokenAction).
 */
model PhotoConsent {
  id           String        @id @default(cuid())
  scoutId      String        @unique
  scout        Scout         @relation(fields: [scoutId], references: [id], onDelete: Cascade)
  token        String        @unique
  facebook     ConsentStatus @default(PENDING)
  website      ConsentStatus @default(PENDING)
  fliers       ConsentStatus @default(PENDING)
  signedByName String?
  signedDate   DateTime?     @db.Date
  signedAt     DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model PhotoAlbum {
  id            String   @id @default(cuid())
  title         String
  eventDate     DateTime @db.Date
  description   String?
  coverImageUrl String?
  photoAlbumUrl String
  isVisible     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
